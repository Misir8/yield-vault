{
  "name": "defi-backend",
  "version": "1.0.0",
  "description": "NestJS backend for DeFi Deposit Platform",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "start:api-gateway": "nest start api-gateway --watch",
    "start:api-gateway:debug": "nest start api-gateway --debug --watch",
    "start:api-gateway:prod": "node dist/apps/api-gateway/main",
    "start:keeper": "nest start keeper --watch",
    "start:keeper:debug": "nest start keeper --debug --watch",
    "start:keeper:prod": "node dist/apps/keeper/main",
    "start:indexer": "nest start indexer --watch",
    "start:indexer:debug": "nest start indexer --debug --watch",
    "start:indexer:prod": "node dist/apps/indexer/main",
    "start:analytics": "nest start analytics --watch",
    "start:analytics:debug": "nest start analytics --debug --watch",
    "start:analytics:prod": "node dist/apps/analytics/main",
    "start:all": "concurrently \"npm run start:api-gateway\" \"npm run start:keeper\" \"npm run start:indexer\" \"npm run start:analytics\"",
    "build:all": "nest build api-gateway && nest build keeper && nest build indexer && nest build analytics",
    "build:api-gateway": "nest build api-gateway",
    "build:keeper": "nest build keeper",
    "build:indexer": "nest build indexer",
    "build:analytics": "nest build analytics",
    "config:validate": "ts-node scripts/validate-config.ts",
    "config:show": "node -e \"console.log(JSON.stringify(require('config'), null, 2))\"",
    "prisma:generate": "prisma generate --schema=apps/indexer/prisma/schema.prisma && prisma generate --schema=apps/analytics/prisma/schema.prisma && prisma generate --schema=apps/api-gateway/prisma/schema.prisma",
    "prisma:generate:indexer": "prisma generate --schema=apps/indexer/prisma/schema.prisma",
    "prisma:generate:analytics": "prisma generate --schema=apps/analytics/prisma/schema.prisma",
    "prisma:generate:api-gateway": "prisma generate --schema=apps/api-gateway/prisma/schema.prisma",
    "prisma:migrate:indexer": "prisma migrate dev --schema=apps/indexer/prisma/schema.prisma --url=$(node scripts/prisma-url.js indexer)",
    "prisma:migrate:analytics": "prisma migrate dev --schema=apps/analytics/prisma/schema.prisma --url=$(node scripts/prisma-url.js analytics)",
    "prisma:migrate:api-gateway": "prisma migrate dev --schema=apps/api-gateway/prisma/schema.prisma --url=$(node scripts/prisma-url.js api-gateway)",
    "prisma:migrate:deploy:indexer": "prisma migrate deploy --schema=apps/indexer/prisma/schema.prisma --url=$(node scripts/prisma-url.js indexer)",
    "prisma:migrate:deploy:analytics": "prisma migrate deploy --schema=apps/analytics/prisma/schema.prisma --url=$(node scripts/prisma-url.js analytics)",
    "prisma:migrate:deploy:api-gateway": "prisma migrate deploy --schema=apps/api-gateway/prisma/schema.prisma --url=$(node scripts/prisma-url.js api-gateway)",
    "prisma:studio:indexer": "prisma studio --schema=apps/indexer/prisma/schema.prisma --port 5555 --url=$(node scripts/prisma-url.js indexer)",
    "prisma:studio:analytics": "prisma studio --schema=apps/analytics/prisma/schema.prisma --port 5556 --url=$(node scripts/prisma-url.js analytics)",
    "prisma:studio:api-gateway": "prisma studio --schema=apps/api-gateway/prisma/schema.prisma --port 5557 --url=$(node scripts/prisma-url.js api-gateway)",
    "prisma:push:indexer": "prisma db push --schema=apps/indexer/prisma/schema.prisma --url=$(node scripts/prisma-url.js indexer)",
    "prisma:push:analytics": "prisma db push --schema=apps/analytics/prisma/schema.prisma --url=$(node scripts/prisma-url.js analytics)",
    "prisma:push:api-gateway": "prisma db push --schema=apps/api-gateway/prisma/schema.prisma --url=$(node scripts/prisma-url.js api-gateway)",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/bull": "^10.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nestjs": "^10.50.0",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.3",
    "axios-retry": "^4.5.0",
    "bull": "^4.11.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "concurrently": "^8.2.2",
    "config": "^3.3.9",
    "ethers": "^6.9.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "multicoin-address-validator": "^0.5.26",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@libs/api-decorators(|/.*)$": "<rootDir>/libs/api-decorators/src/$1",
      "^libs/exceptions(|/.*)$": "<rootDir>/libs/exceptions/src/$1",
      "^libs/constants(|/.*)$": "<rootDir>/libs/constants/src/$1",
      "^@libs/logger(|/.*)$": "<rootDir>/libs/logger/src/$1",
      "^@libs/health(|/.*)$": "<rootDir>/libs/health/src/$1",
      "^@libs/axios(|/.*)$": "<rootDir>/libs/axios/src/$1",
      "^@libs/indexer-provider(|/.*)$": "<rootDir>/libs/indexer-provider/src/$1",
      "^@libs/indexer-types(|/.*)$": "<rootDir>/libs/indexer-types/src/$1"
    }
  }
}
